---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = getSortedPosts(await getCollection("posts"));
const recentPosts = posts.slice(0, config.posts.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section class="river-hero mx-auto max-w-2xl py-16 sm:py-24">
      <div class="bg-accent mb-6 h-0.5 w-8"></div>
      <h1
        class="font-editorial text-4xl leading-[1.35] font-medium tracking-[0.035em] sm:text-5xl"
      >
        思考，学习，<br />与沿途所得。
      </h1>
      <p class="text-muted-foreground mt-6 max-w-xl text-[0.95rem] leading-8">
        记录个人思考、学习过程、技术实践与阶段成果。使用网名写作，缓慢更新，长期保留。
      </p>
      <LinkButton
        class="text-accent mt-5 inline-flex items-center gap-1 text-sm"
        href={getRelativeLocaleUrl(locale, "about")}
      >
        了解 River 与联系方式 <IconArrowRight class="size-4" />
      </LinkButton>
    </section>

    <section class="mx-auto max-w-2xl pb-14">
      <div
        class="border-foreground flex items-end justify-between border-b pb-3"
      >
        <h2 class="font-editorial text-lg font-semibold tracking-[0.08em]">
          最近文章
        </h2>
        {
          posts.length > 0 && (
            <LinkButton
              class="text-muted-foreground hover:text-accent text-xs"
              href={getRelativeLocaleUrl(locale, "posts")}
            >
              查看全部
            </LinkButton>
          )
        }
      </div>

      {
        recentPosts.length > 0 ? (
          <ul>
            {recentPosts.map(post => (
              <Card variant="h3" {...post} />
            ))}
          </ul>
        ) : (
          <p class="text-muted-foreground py-8 text-sm leading-7">
            文章正在形成。这里不会用占位内容填满页面。
          </p>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
