---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const currentYear = new Date().getFullYear();
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border text-muted-foreground flex flex-col gap-4 border-t py-6 text-sm sm:flex-row sm:items-center sm:justify-between"
  >
    <nav aria-label="联系与订阅" class="flex flex-wrap gap-x-5 gap-y-2">
      <a class="hover:text-accent" href="mailto:ruhai3937@gmail.com">邮箱</a>
      <a
        class="hover:text-accent"
        href="https://github.com/LinRuhai328"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      <a
        class="hover:text-accent"
        href={getRelativeLocaleUrl(locale, "rss.xml")}>RSS</a
      >
    </nav>
    <span>© {currentYear} River</span>
  </div>
</footer>
