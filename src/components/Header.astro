---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconX from "@/assets/icons/IconX.svg";
import { stripBase, stripLocale } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const relativePath = stripBase(Astro.url.pathname);
const currentPath = stripLocale(
  relativePath.endsWith("/") && relativePath !== "/"
    ? relativePath.slice(0, -1)
    : relativePath,
  locale
);

const isActive = (path: string) =>
  path === "/"
    ? currentPath === "/"
    : currentPath === path || currentPath.startsWith(`${path}/`);

const links = [
  { path: "/", href: "", label: t.nav.home },
  { path: "/posts", href: "posts", label: t.nav.posts },
  { path: "/archives", href: "archives", label: t.nav.archives },
  { path: "/about", href: "about", label: t.nav.about },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="bg-background text-accent absolute inset-s-16 -top-full z-50 px-3 py-2 transition-all focus:top-4"
>
  {t.a11y.skipToContent}
</a>

<header class="app-layout">
  <div
    class="border-border flex min-h-20 items-center justify-between border-b py-4"
  >
    <a
      href={getRelativeLocaleUrl(locale, "")}
      class="font-editorial text-xl font-semibold tracking-[0.08em] sm:text-2xl"
    >
      {config.site.title}
    </a>

    <nav id="nav-menu" aria-label="主导航">
      <button
        id="menu-btn"
        class="focus-outline relative size-10 p-2 sm:hidden"
        aria-label={t.a11y.openMenu}
        aria-expanded="false"
        aria-controls="menu-items"
        data-label-open={t.a11y.openMenu}
        data-label-close={t.a11y.closeMenu}
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>

      <ul
        id="menu-items"
        class="border-border bg-background absolute inset-x-4 top-20 z-40 hidden border px-5 py-3 shadow-sm sm:static sm:flex sm:items-center sm:gap-6 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none"
      >
        {
          links.map(({ path, href, label }) => (
            <li>
              <a
                href={getRelativeLocaleUrl(locale, href)}
                aria-current={isActive(path) ? "page" : undefined}
                class:list={[
                  "block py-3 text-sm tracking-wide sm:py-1",
                  isActive(path)
                    ? "text-accent"
                    : "text-muted-foreground hover:text-foreground",
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
        <li>
          <button
            id="theme-btn"
            class="focus-outline relative my-1 size-10 p-2 sm:my-0 sm:size-8"
            title={t.a11y.toggleTheme}
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon
              class="absolute top-1/2 left-1/2 size-5 -translate-1/2 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90"
            />
            <IconSunHigh
              class="absolute top-1/2 left-1/2 size-5 -translate-1/2 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0"
            />
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function setupNavigation() {
    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", String(!isOpen));
      menuBtn.setAttribute(
        "aria-label",
        isOpen
          ? (menuBtn.dataset.labelOpen ?? "打开菜单")
          : (menuBtn.dataset.labelClose ?? "关闭菜单")
      );
      menuItems.classList.toggle("hidden", isOpen);
      menuIcon.classList.toggle("hidden", !isOpen);
      closeIcon.classList.toggle("hidden", isOpen);
    });
  }

  setupNavigation();
  document.addEventListener("astro:after-swap", setupNavigation);
</script>
